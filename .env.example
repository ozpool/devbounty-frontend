# Public client config (all exposed to the browser — never put secrets here).

# Backend API base URL (cookie auth; no /api prefix).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# WalletConnect Cloud project id (https://cloud.walletconnect.com).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Chain config — Arbitrum Sepolia.
NEXT_PUBLIC_CHAIN_ID=421614

# RPC endpoint override (Alchemy/Infura). Falls back to the public, rate-limited
# Arbitrum Sepolia RPC if empty — set this before on-chain reads go live.
NEXT_PUBLIC_RPC_URL=

# Token + escrow addresses. ESCROW is empty until the contract is deployed.
NEXT_PUBLIC_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
NEXT_PUBLIC_ESCROW_ADDRESS=

# GitHub OAuth client id (linking flow lives on the backend; id is public).
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# Sentry (optional).
NEXT_PUBLIC_SENTRY_DSN=

# Demo mode — serve seeded dummy data instead of calling the API. Set to "true"
# to deploy a fully clickable demo with no backend running.
NEXT_PUBLIC_DEMO_MODE=false
